# Undeployed Capital — Daily Brief
# Copy this file to .env and fill in your values.
# Then: export $(cat .env | xargs) before running.

# Required — get from https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-YOUR_KEY_HERE

# Optional — only needed if using --email flag
BRIEF_EMAIL_FROM=your@gmail.com
BRIEF_EMAIL_PASS=your-gmail-app-password
